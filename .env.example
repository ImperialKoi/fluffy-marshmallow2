# Copy to .env and fill in. Load into your shell with:
#   set -a && source .env && set +a
# Never commit your real .env. All credentials are read from the environment;
# nothing is ever hardcoded.

# ---------------------------------------------------------------------------
# Alpaca — paper trading + market data + news (free with an Alpaca account)
# Get paper keys at https://app.alpaca.markets  (paper keys are fine for data)
# ---------------------------------------------------------------------------
ALPACA_KEY=
ALPACA_SECRET=

# Alpaca LIVE trading (real money). Leave blank unless you mean it. Live also
# requires ALPACA_ALLOW_LIVE=yes AND typing the confirmation phrase at runtime.
ALPACA_LIVE_KEY=
ALPACA_LIVE_SECRET=
ALPACA_ALLOW_LIVE=

# ---------------------------------------------------------------------------
# Real-time information tool (tools/info/)
# ---------------------------------------------------------------------------
# SEC EDGAR REQUIRES a descriptive User-Agent containing a contact email, or it
# blocks/limits you. Format: "Your Name your@email.com". Without it the EDGAR
# adapter still tries with a generic UA but may be denied.
SEC_EDGAR_USER_AGENT=

# Info-tool cache (optional overrides)
# INFO_CACHE_PATH=results/info_cache.db   # SQLite cache location
# INFO_CACHE_TTL=600                       # cache TTL in seconds (default 600 = 10 min)

# Live smoke test for the info tool is gated behind this flag (see tests/).
# RUN_LIVE_INFO_TESTS=1

# ---------------------------------------------------------------------------
# Hype tracker — OPTIONAL social sources (OFF by default in config.py)
# Only needed if you set HYPE_ENABLE_REDDIT = True. Enabling social sources
# reverses the project's earlier "no social sources" decision — opt-in only.
# ---------------------------------------------------------------------------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=trading-bot-hype/1.0

# ---------------------------------------------------------------------------
# Phase 3 AI strategy (agents/) — Gemini LLM
# Get a free key at https://aistudio.google.com/apikey
# Without this key, live_portfolio.py falls back to an offline StubLLM (clearly
# labeled, NOT the real model) so the pipeline still runs end-to-end for testing.
# ---------------------------------------------------------------------------
GEMINI_API_KEY=

# LLM fallback chain (optional): Gemini -> Cohere -> OpenAI. Each is used only if
# its key is set; the chain rolls over when a provider is unreachable/overloaded.
COHERE_API_KEY=
OPENAI_API_KEY=
