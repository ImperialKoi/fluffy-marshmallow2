# Byte-compiled / optimized / cached
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Secrets / credentials — NEVER commit Alpaca keys
.env
.env.*
!.env.example

# Runtime output (logs, kill-switch state, charts, trade logs)
results/
*.log

# Data caches (large; regenerate via loader).
# Keep the bundled validation dataset tracked; ignore other downloads.
data_cache/*
!data_cache/sp500_5yr.csv

# Test / coverage artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# Notebooks
.ipynb_checkpoints/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
